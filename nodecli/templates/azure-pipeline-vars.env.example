# Template .env để set Azure Pipeline Variables bằng ocli azure
# Cú pháp: KEY=value (mỗi dòng)
# Dòng bắt đầu bằng # là comment, bị bỏ qua
# Tất cả variable từ .env sẽ có isSecret=false, allowOverride=true
# Muốn set isSecret=true → dùng file JSON thay thế

BUILD_ENV=production
API_BASE_URL=https://api.example.com
DEPLOY_TIMEOUT=300
MAX_RETRIES=3
